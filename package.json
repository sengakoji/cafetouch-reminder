  "devDependencies": {
    "@capacitor/cli": "^8.1.0",
    "@playwright/test": "^1.58.2",
    "dotenv": "^17.3.1",
    "esbuild": "^0.27.3"
  },
  "dependencies": {
    "@capacitor/android": "^8.1.0",
