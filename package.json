  "main": "sw.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "cap-build": "npx esbuild cap-entry.js --bundle --outfile=cap-bundle.js --minify",
    "build": "npm run cap-build && pwsh -Command \"New-Item -ItemType Directory -Force -Path www; Copy-Item index.html, sw.js, cap-bundle.js, site.webmanifest, *.png, favicon.ico, favicon.svg -Destination www -Force\"",
    "build:android": "npm run build && npx cap sync android"
  },
